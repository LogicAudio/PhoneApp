# Dependencies
node_modules/

# macOS
.DS_Store

# Logs
*.log

# Android build outputs (the android/ project template itself IS committed)
apps/*/android/.gradle/
apps/*/android/build/
apps/*/android/app/build/
apps/*/android/local.properties
apps/*/android/.idea/
apps/*/android/captures/

# Generated by `cap sync` (copies of www/ and config)
apps/*/android/app/src/main/assets/public/
apps/*/android/app/src/main/assets/capacitor.config.json
apps/*/android/app/src/main/assets/capacitor.plugins.json

# Signing keys — never commit release keystores
*.keystore
*.jks
